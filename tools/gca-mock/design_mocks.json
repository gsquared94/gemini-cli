  "POST /v1internal:streamGenerateContent": {
    "endpoint": "/v1internal:streamGenerateContent",
    "method": "POST",
    "responses": [
      {
        "statusCode": 429,
        "body": {
          "error": {
            "code": 429,
            "message": "Quota exceeded",
            "status": "RESOURCE_EXHAUSTED",
            "details": [
              {
                "@type": "type.googleapis.com/google.rpc.ErrorInfo",
                "reason": "QUOTA_EXHAUSTED",
                "domain": "cloudcode-pa.googleapis.com",
                "metadata": {
                  "service": "cloudcode-pa.googleapis.com"
                }
              }
            ]
          }
        }
      },
      {
        "statusCode": 200,
        "chunks": [
          {
            "response": {
              "candidates": [
                {
                  "content": {
                    "parts": [
                      {
                        "text": "Generated with AI Credits!"
                      }
                    ]
                  }
                }
              ],
              "consumed_credits": [
                {
                  "credit_type": "GOOGLE_ONE_AI",
                  "credit_amount": "50"
                }
              ],
              "remaining_credits": [
